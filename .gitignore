# Dependencies
node_modules/

# Build output
dist/
build/
dashboard/dist/
*.tsbuildinfo
*.d.ts.map

# Runtime config (use openclaw.example.json as template)
config/openclaw.json
config/*.bak
config/*.bak.*

# Environment
.env
.env.local
.env.production

# SQLite databases (both .sqlite and .db patterns)
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
*.db-wal
*.db-shm
.research-claw/

# OS
.DS_Store
Thumbs.db

# Claude Code worktrees
.claude/worktrees/

# Claude Code local settings
.claude/settings.local.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Coverage
coverage/

# Temp
.tmp/
.tools/
dashboard/test-image-send.mjs

# Lock files (using pnpm, not npm)
extensions/*/package-lock.json

# Workspace runtime data
# All prompt files live in workspace/.ResearchClaw/ (loaded via agent:bootstrap hook).
# Root-level copies (AGENTS.md, HEARTBEAT.md) are synced by run.sh for OC compatibility
# but must not be tracked — .ResearchClaw/ versions are the source of truth.
workspace/*
!workspace/.gitignore
!workspace/.ResearchClaw/
!workspace/MEMORY.md.example
!workspace/USER.md.example
workspace/SOUL.md
workspace/IDENTITY.md
workspace/TOOLS.md
workspace/HEARTBEAT.md
workspace/USER.md
workspace/MEMORY.md
workspace/.ResearchClaw/SOUL.md
workspace/.ResearchClaw/IDENTITY.md
workspace/.ResearchClaw/TOOLS.md
workspace/.ResearchClaw/USER.md
workspace/.ResearchClaw/BOOTSTRAP.md
workspace/.ResearchClaw/BOOTSTRAP.md.done
workspace/.ResearchClaw/*_backup_*.md
workspace/.openclaw/
workspace/memory/
workspace/sources/
workspace/skills_collection/
workspace/outputs/
workspace/workspace/
workspace/*.csv
workspace/*.bib
workspace/*.json
workspace/*.py
workspace/*.ipynb
workspace/*.txt
workspace/helloworld.md
workspace/test-scenarios.md
workspace/*_report*.md
workspace/uploads/*
workspace/ml-project/
